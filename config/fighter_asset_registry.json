    "intense": "portrait_intense_base.png",
    "smug": "portrait_smug_base.png",
    "wild": "portrait_wild_base.png",
    "heroic": "portrait_heroic_base.png"
  },
  "ai_packages": {
    "balanced_v1": "ai/balanced_v1.json",
    "rushdown_v1": "ai/rushdown_v1.json",
    "grappler_v1": "ai/grappler_v1.json",
    "striker_v1": "ai/striker_v1.json",
    "zoner_v1": "ai/zoner_v1.json",
    "counter_v1": "ai/counter_v1.json",
    "tank_v1": "ai/tank_v1.json",
    "wildcard_v1": "ai/wildcard_v1.json"
  },
  "assembly_modules": {
    "body_class": {
      "lightweight_striker": {
        "allowed_archetypes": ["rushdown", "striker", "zoner"],
        "runtime_template": "template_strike_01"
      },
      "balanced_midweight": {
        "allowed_archetypes": ["balanced", "wildcard", "rushdown", "striker"],
        "runtime_template": "template_balanced_01"
      },
      "heavy_grappler": {
        "allowed_archetypes": ["grappler", "counter_grappler", "tank"],
        "runtime_template": "template_grapple_01"
      }
    },
    "locomotion_package": {
      "measured_step": {
        "allowed_body_classes": ["balanced_midweight", "heavy_grappler"]
      },
      "pressure_walk": {
        "allowed_body_classes": ["balanced_midweight", "lightweight_striker"]
      },
      "ring_cutter": {
        "allowed_body_classes": ["lightweight_striker"]
      },
      "juggernaut_stride": {
        "allowed_body_classes": ["heavy_grappler"]
      }
    },
    "strike_package": {
      "balanced_hands": {
        "allowed_archetypes": ["balanced", "wildcard", "striker"]
      },
      "kick_volley": {
        "allowed_archetypes": ["rushdown", "striker"]
      },
      "counter_shots": {
        "allowed_archetypes": ["counter_grappler", "balanced"]
      },
      "heavy_club": {
        "allowed_archetypes": ["tank", "grappler"]
      }
    },
    "grapple_package": {
      "fundamental_grabs": {
        "allowed_archetypes": ["balanced", "wildcard", "striker"]
      },
      "chain_wrestling": {
        "allowed_archetypes": ["grappler", "counter_grappler", "balanced"]
      },
      "power_throws": {
        "allowed_archetypes": ["grappler", "tank"]
      }
    },
    "special_package": {
      "ring_general": {
        "allowed_archetypes": ["balanced", "wildcard"]
      },
      "burst_offense": {
        "allowed_archetypes": ["rushdown", "striker"]
      },
      "space_control": {
        "allowed_archetypes": ["zoner", "striker"]
      },
      "shutdown_counter": {
        "allowed_archetypes": ["counter_grappler", "tank"]
      }
    },
    "intro_package": {
      "calm_walkout": {
        "allowed_alignments": ["face", "tweener", "heel"]
      },
      "spotlight_pose": {
        "allowed_alignments": ["face", "tweener"]
      },
      "menace_stare": {
        "allowed_alignments": ["heel", "tweener"]
      }
    },
    "victory_package": {
      "stoic_exit": {
        "allowed_alignments": ["face", "tweener", "heel"]
      },
      "crowd_pop": {
        "allowed_alignments": ["face", "tweener"]
      },
      "cold_dismissal": {
        "allowed_alignments": ["heel", "tweener"]
      }
    }
  },
  "moves": {
    "signature_moves": [
      "spinebuster",
      "counter_slam",
      "lariat",
      "roundhouse_burst",
      "knee_combo",
      "backfist",
      "dropkick",
      "suplex_throw"
    ],
    "finishers": [
      "sitout_powerbomb",
      "storm_drop",
      "flash_high_kick",
      "super_lariat",
      "driver_drop",
      "skybreaker"
    ],
    "super_finishers": [
      "storm_drop",
      "chaos_driver",
      "critical_burst",
      "last_stand_bomb"
    ]
  },
  "compatibility_rules": {
    "archetype_to_template": {
      "balanced": ["template_balanced_01", "template_counter_01"],
      "rushdown": ["template_rush_01"],
      "grappler": ["template_grapple_01"],
      "striker": ["template_strike_01"],
      "zoner": ["template_zone_01"],
      "counter_grappler": ["template_grapple_01", "template_counter_01"],
      "tank": ["template_tank_01"],
      "wildcard": ["template_wild_01"]
    },
    "disallowed_combinations": [
      {
        "field_a": "appearance.hair_style",
        "value_a": "hooded",
        "field_b": "appearance.mask_style",
        "value_b": "full_mask",
        "reason": "hood and full mask overlap visually"
      },
      {
        "field_a": "appearance.body_type",
        "value_a": "giant",
        "field_b": "appearance.gear_top",
        "value_b": "armor_light",
        "reason": "unsupported sprite combination"
      }
    ],
    "body_class_to_template": {
      "lightweight_striker": ["template_strike_01", "template_rush_01"],
      "balanced_midweight": ["template_balanced_01", "template_wild_01"],
      "heavy_grappler": ["template_grapple_01", "template_tank_01", "template_counter_01"]
    }
  }
}
